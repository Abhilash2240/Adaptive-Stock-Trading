# ─── Adaptive Stock Trading — Environment Configuration ───────────
# Copy this file to `.env` and fill in your values.
#   cp .env.example .env

# ── General ──
ENVIRONMENT=development

# ── Database (pick one) ──
# Option A: Neon (free cloud PostgreSQL) — https://neon.tech
DATABASE_URL=postgresql://user:password@ep-xyz.us-east-2.aws.neon.tech/neondb?sslmode=require
# Option B: Local Docker — run `docker compose up -d` first
# DATABASE_URL=postgresql://trader:trader_dev_pass@localhost:5432/trading_db

# ── Market Data ──
POLYGON_API_KEY=your-polygon-api-key
DATA_PROVIDER=mock
SYMBOLS=AAPL,MSFT,TSLA
MOCK_STREAM_INTERVAL=0.5
POLYGON_POLL_INTERVAL=1.0

# ── Security ──
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Firebase / GCP (optional) ──
FIREBASE_PROJECT_ID=
FIREBASE_AUTH_AUDIENCE=
PUBSUB_TOPIC=
MODEL_BUCKET=
AGENT_MODEL_NAME=ppo-default
