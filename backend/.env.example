# Backend configuration defaults
# Copy to backend/.env and adjust values for your environment.

ENVIRONMENT=development
DATA_PROVIDER=mock
SYMBOLS=AAPL,MSFT,TSLA
MOCK_STREAM_INTERVAL=1.0
POLYGON_POLL_INTERVAL=1.0
POLYGON_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_AUTH_AUDIENCE=
PUBSUB_TOPIC=
MODEL_BUCKET=
AGENT_MODEL_NAME=ppo-default

# Security Configuration
JWT_SECRET_KEY=change-this-super-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Rate Limiting
RATE_LIMIT_ENABLED=true

# Database Configuration
# Option A: FREE Neon cloud PostgreSQL (https://neon.tech)
# DATABASE_URL=postgresql://user:pass@ep-xyz.us-east-2.aws.neon.tech/trading_db?sslmode=require
# Option B: Local Docker (run `docker compose up -d`)
DATABASE_URL=postgresql://trader:trader_dev_pass@localhost:5432/trading_db

# Redis Configuration (for rate limiting)
REDIS_URL=redis://localhost:6379/0

# CORS Configuration (development)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# Logging
LOG_LEVEL=INFO
AUDIT_LOG_ENABLED=true
